# ---- 1) deps ----
FROM node:22-alpine AS deps
WORKDIR /app

# Dependências (melhor cache)
COPY package*.json ./
RUN npm ci

# ---- 2) build ----
FROM node:22-alpine AS build
WORKDIR /app
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build do Astro (SSR)
RUN npm run build

# ---- 3) runtime ----
FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production

# Segurança básica
RUN addgroup -S nodejs && adduser -S astro -G nodejs

# Copia o output standalone do adapter node
# (com mode: "standalone", o dist/ já vem “pronto” para rodar)
COPY --from=build /app/dist ./dist

# Se o adapter gerar node_modules runtime dentro de dist (standalone), ótimo.
# Se não, copiamos os node_modules do build como fallback (seguro).
# (Não custa muito e evita "Cannot find module" em alguns setups)
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json

# Porta padrão (Dokploy pode mapear, mas Astro precisa escutar)
ENV HOST=0.0.0.0
ENV PORT=3000
EXPOSE 3000

USER astro

# Start SSR
CMD ["node", "dist/server/entry.mjs"]